{
  "name": "hacker-podcast",
  "type": "module",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "deploy": "vinext deploy",
    "preview": "vinext build && vinext start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks",
    "dev:worker": "wrangler dev --cwd worker -c wrangler.jsonc --persist-to ../.wrangler/state",
    "deploy:worker": "wrangler deploy --cwd worker",
    "logs:worker": "wrangler tail --cwd worker",
    "tests": "wrangler dev --cwd tests --remote",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "wrangler": "wrangler"
  },
  "devDependencies": {
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@antfu/eslint-config": "^9.0.0",
    "@base-ui/react": "^1.5.0",
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/vite-plugin": "^1.40.1",
    "@echristian/edge-tts": "^0.0.14",
    "@eslint-react/eslint-plugin": "^5.8.17",
    "@remixicon/react": "^4.9.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-store": "^0.11.0",
    "@tanstack/store": "^0.11.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "<23",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@unpic/react": "^1.0.2",
    "@vidstack/react": "^1.15.5",
    "@vitejs/plugin-rsc": "^0.5.27",
    "@xsai/generate-speech": "0.5.0-beta.2",
    "ai": "^6.0.199",
    "baseline-browser-mapping": "^2.10.35",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^10.4.1",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "lint-staged": "^17.0.7",
    "markdown-it": "^14.2.0",
    "media-icons": "^1.1.5",
    "motion": "^12.40.0",
    "ofetch": "^1.5.1",
    "podcast": "^2.0.1",
    "puppeteer": "^22.8.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-medium-image-zoom": "^5.4.7",
    "react-server-dom-webpack": "^19.2.7",
    "remark-gfm": "^4.0.1",
    "simple-git-hooks": "^2.13.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "unspeech": "^0.1.14",
    "vidstack": "^1.15.5",
    "vinext": "^0.1.1",
    "vite": "^8.0.16",
    "wrangler": "^4.99.0",
    "zod": "^4.4.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
