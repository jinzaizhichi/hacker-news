{
  "compilerOptions": {
    "incremental": true,
    "target": "ES2017",
    "jsx": "preserve",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "./*"
      ],
      "next/navigation": [
        "./node_modules/vinext/dist/shims/navigation"
      ],
      "next/server": [
        "./node_modules/vinext/dist/shims/server"
      ],
      "next/link": [
        "./node_modules/vinext/dist/shims/link"
      ],
      "next/image": [
        "./node_modules/vinext/dist/shims/image"
      ]
    },
    "resolveJsonModule": true,
    "types": ["vite/client", "react", "react-dom"],
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": [
    "cloudflare-env.d.ts",
    "vite-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
